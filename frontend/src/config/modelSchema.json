{
  "name": "Epidemic GPU",
  "controls": [
    { "type": "button", "id": "setup", "label": "Setup" },
    { "type": "toggle", "id": "go", "label": "Go" },
    { "type": "number", "id": "agent_count", "label": "Agent Count (Max 1M)", "min": 1, "max": 1000000, "step": 1000, "default": 100000 },
    { "type": "slider", "id": "infection_radius", "label": "Infection Radius", "min": 0.05, "max": 2.0, "step": 0.05 },
    { "type": "slider", "id": "initial_infected", "label": "Initial Infected", "min": 1, "max": 1000, "step": 1 },
    { "type": "slider", "id": "transmission_probability", "label": "Transmission Probability", "min": 0.0, "max": 1.0, "step": 0.01 },
    { "type": "slider", "id": "recovery_time", "label": "Recovery Time (sec)", "min": 1.0, "max": 60.0, "step": 1.0 }
  ],
  "plots": [
    { "id": "telemetry", "title": "Real-time Telemetry" }
  ],
  "monitors": [
    { "id": "macro_engine", "label": "Macro Engine", "value": "Shachi (Python LLM)" }
  ]
}
